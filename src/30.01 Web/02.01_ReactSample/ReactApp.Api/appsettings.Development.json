{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Diginsight": "Debug",
      "*.BodyLoggingHandler": "Trace",
      "ReactApp.Api": "Trace"
    }
  },
  "Observability": {
    "ConsoleEnabled": true,
    "Log4NetEnabled": true,
    "DebugEnabled": false
  },
  "Diginsight": {
    "Console": {
      "UseColor": true
    }
  }
}
