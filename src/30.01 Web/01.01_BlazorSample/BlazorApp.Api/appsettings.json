{
  "AppHosting": {
    "PathBase": ""
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "",
    "TenantId": "",
    "ClientId": "",
    "CallbackPath": "/signin-oidc",
    "Scopes": "access_as_user"
  },
  "AzureKeyVault": {
    "Uri": ""
  },
  "BlazorClientAuth": {
    "ClientId": "",
    "Authority": "",
    "ValidateAuthority": true,
    "Scopes": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7259",
      "http://localhost:5049"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "*.BodyLoggingHandler": "Warning"
    }
  },
  "Diginsight": {
    "Activities": {
      "LogBehavior": "Show",
      "LogLevel": "Debug",
      "RecordSpanDuration": true,
      "MeterName": "BlazorApp.Api",
      "ActivitySources": {
        "Microsoft.AspNetCore": true,
        "System.Net.Http": true,
        "Experimental.*": false,
        "Diginsight.*": true,
        "BlazorApp.Api": true
      },
      "LoggedActivityNames": {
        "System.Net.Http|System.Net.Http.HttpRequestOut": "Hide",
        "Microsoft.AspNetCore.Hosting.HttpRequestIn": "Hide"
      }
    }
  },
  "Observability": {
    "ConsoleEnabled": true,
    "Log4NetEnabled": true,
    "DebugEnabled": false
  },
  "OpenTelemetry": {
    "EnableTraces": true,
    "EnableMetrics": true,
    "AzureMonitorConnectionString": "",
    "ActivitySources": [
      "Microsoft.AspNetCore",
      "Diginsight.*",
      "BlazorApp.Api"
    ],
    "Meters": [
      "BlazorApp.Api"
    ],
    "ExcludedHttpHosts": [
      "login.microsoftonline.com",
      ".applicationinsights.azure.com",
      ".monitor.azure.com",
      ".b2clogin.com"
    ]
  },
  "AllowedHosts": "*",
  "IsSwaggerEnabled": true
}
