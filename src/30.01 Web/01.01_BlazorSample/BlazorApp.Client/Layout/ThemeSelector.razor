@inject IJSRuntime JS

<div class="dropdown theme-selector @(_open ? "show" : null)">
    <button class="btn btn-sm dropdown-toggle theme-toggle" type="button"
            @onclick="Toggle" @onclick:stopPropagation aria-expanded="@_open" title="Change theme">
        <span class="theme-swatch" style="background:@CurrentTheme.Swatch"></span>
        <span class="theme-label d-none d-sm-inline">@CurrentTheme.Label</span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end @(_open ? "show" : null)">
        <li><h6 class="dropdown-header">Light</h6></li>
        @foreach (var theme in Themes)
        {
            @if (theme.Mode == "light")
            {
                @ThemeItem(theme)
            }
        }
        <li><hr class="dropdown-divider" /></li>
        <li><h6 class="dropdown-header">Dark</h6></li>
        @foreach (var theme in Themes)
        {
            @if (theme.Mode == "dark")
            {
                @ThemeItem(theme)
            }
        }
    </ul>
</div>
@if (_open)
{
    <div class="theme-backdrop" @onclick="Close"></div>
}

@code {
    private sealed record ThemeOption(string Id, string Label, string Mode, string Swatch);

    // Keep the id -> mode mapping in sync with THEME_MODES in wwwroot/js/app-ui.js
    // and the inline bootstrap script in wwwroot/index.html.
    private static readonly ThemeOption[] Themes =
    {
        new("azure", "Azure", "light", "#2563eb"),
        new("emerald", "Emerald", "light", "#059669"),
        new("teal", "Teal", "light", "#0d9488"),
        new("violet", "Violet", "light", "#7c3aed"),
        new("sunset", "Sunset", "light", "#ea580c"),
        new("midnight", "Midnight", "dark", "#0f172a"),
        new("slate", "Slate", "dark", "#272b30"),
        new("carbon", "Carbon", "dark", "#18181b"),
    };

    private string _current = "azure";
    private bool _open;

    private ThemeOption CurrentTheme =>
        Array.Find(Themes, t => t.Id == _current) ?? Themes[0];

    private void Toggle() => _open = !_open;

    private void Close() => _open = false;

    private RenderFragment ThemeItem(ThemeOption theme) => __builder =>
    {
        <li>
            <button class="dropdown-item d-flex align-items-center @(theme.Id == _current ? "active" : null)"
                    type="button" @onclick="() => SelectThemeAsync(theme.Id)">
                <span class="theme-swatch me-2" style="background:@theme.Swatch"></span>
                <span class="flex-grow-1">@theme.Label</span>
                @if (theme.Id == _current)
                {
                    <span class="theme-check ms-2">@CheckIcon</span>
                }
            </button>
        </li>
    };

    private static readonly MarkupString CheckIcon = new(
        "<svg width=\"14\" height=\"14\" viewBox=\"0 0 16 16\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z\"/></svg>");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string>("appUi.getTheme");
            if (!string.IsNullOrEmpty(saved) && saved != _current)
            {
                _current = saved;
                StateHasChanged();
            }
        }
    }

    private async Task SelectThemeAsync(string id)
    {
        _current = id;
        _open = false;
        await JS.InvokeAsync<string>("appUi.applyTheme", id);
    }
}
