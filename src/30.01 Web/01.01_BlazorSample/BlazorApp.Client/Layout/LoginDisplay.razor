@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using BlazorApp.Client.Configuration
@inject NavigationManager Navigation
@inject ClientAuthBootstrapState AuthState

<AuthorizeView>
    <Authorized>
        Hello, @context.User.Identity?.Name!
        <button class="nav-link btn btn-link" @onclick="BeginLogOut">Log out</button>
    </Authorized>
    <NotAuthorized>
        @if (AuthState.IsAuthenticationConfigured)
        {
            <a href="authentication/login">Log in</a>
        }
        else
        {
            <span class="text-body-secondary small" title="The server did not provide an authentication configuration (the API may not be running).">Sign-in unavailable</span>
        }
    </NotAuthorized>
</AuthorizeView>

@code{
    public void BeginLogOut()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}
