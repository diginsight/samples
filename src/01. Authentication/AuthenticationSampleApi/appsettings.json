    "ExcludedHttpHosts": [
      "login.microsoftonline.com",
      ".documents.azure.com",
      ".applicationinsights.azure.com",
      ".monitor.azure.com",
      ".b2clogin.com"
    ],
    "DurationMetricTags": [
      "widget_template",
      "site_name"
    ]
  },
  "Diginsight": {
    "Activities": {
      "ActivitySources": [
        "Azure.Cosmos.Operation",
        "Azure.Storage.Blobs.BlobBaseClient",
        "Microsoft.AspNetCore",
        "System.Net.Http",
        "SampleWebApi",
        "Diginsight.*"
        //"*"
      ],
      "LogActivities": true,
      "RecordSpanDurations": true
      //"DisablePayloadRendering": true
